# --- Postgres / pgvector --------------------------------------------------
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=smart_travel_planner
POSTGRES_HOST=localhost
# Host port — set to 5433 by default to avoid collision with a native
# Postgres that may already be using 5432 on your machine.
POSTGRES_PORT=5433

# Async URL is what the app uses at runtime (psycopg v3 async driver).
# Sync URL is what Alembic uses for migrations.
DATABASE_URL=postgresql+psycopg://...:...@localhost:5433/smart_travel_planner
DATABASE_URL_SYNC=postgresql+psycopg://...:...@localhost:5433/smart_travel_planner

# --- Voyage embeddings ----------------------------------------------------
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-4-large
# Output dimension passed to the Voyage API. Must match the pgvector column
# dimension in the migration (default 1024). Changing this means a new
# migration to alter the embedding column.
VOYAGE_DIM=1024
# Free Voyage accounts (no payment method on file) are capped at 3 RPM /
# 10K TPM. Leave this true to throttle the embedder so the ingest doesn't
# hit RateLimitError. Set to false once you've added a card on the Voyage
# dashboard — your 200M free tokens still apply.
VOYAGE_FREE_TIER=true

# --- App ------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
ML_MODEL_PATH=./model/travel_style_classifier.joblib

# --- Auth (JWT) -----------------------------------------------------------
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Agent LLM (Google AI Studio) -----------------------------------------
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
# Strong model — final synthesis.
AGENT_MODEL=gemma-4-31b-it
# Cheap model — tool selection / argument extraction.
# Must support function calling — use a Gemini model (Gemma models on
# Google AI do not support function calling).
# Cheap model — tool selection / argument extraction (must support function calling).
# Use a lighter model when available, e.g. gemini-2.0-flash.
# If your API key only has Gemma access, set both to gemma-4-31b-it.
AGENT_CHEAP_MODEL=gemma-4-31b-it

# --- LangSmith tracing -------------------------------------------------------
# Sign up at https://smith.langchain.com — free tier is enough.
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=smart-travel-planner
